# ========== Required: Storage ==========
STORAGE_CONNECTION_STRING=
RAW_VIDEO_CONTAINER=raw-videos
SEARCH_DOCS_CONTAINER=search-docs

# ========== Required: Content Understanding ==========
CU_ENDPOINT=
CU_API_KEY=
CU_API_VERSION=2025-11-01
CU_ANALYZER_ID=prebuilt-videoSearch

# ========== Required: Azure AI Search ==========
SEARCH_ENDPOINT=
SEARCH_ADMIN_KEY=
SEARCH_API_VERSION=2025-09-01
SEARCH_INDEX_NAME=video-chunks-index
SEARCH_DATASOURCE_NAME=video-chunks-ds
SEARCH_SKILLSET_NAME=video-chunks-skillset
SEARCH_INDEXER_NAME=video-chunks-indexer

# ========== Required: Embedding (used by Search skillset) ==========
AOAI_ENDPOINT=
AOAI_API_KEY=
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AOAI_EMBEDDING_MODEL_NAME=text-embedding-3-small
AOAI_EMBEDDING_DIMENSIONS=1536

# ========== Optional: Chat/Summary model (OpenAI Responses API) ==========
CHAT_MODEL_ENDPOINT=
CHAT_MODEL_DEPLOYMENT=
# If omitted, falls back to AOAI_API_KEY
CHAT_MODEL_API_KEY=

# ========== Optional: Query behavior ==========
TOP_K=5
CANDIDATE_K=50
ENABLE_INTRA_CHUNK_JUMP=true
SEARCH_JUMP_PREROLL_SECONDS=0
AUTO_PROVISION_ON_STARTUP=true
AUTO_PROVISION_FAIL_FAST=false

# Optional: datasource soft delete support
SOFT_DELETE_COLUMN_NAME=
SOFT_DELETE_MARKER_VALUE=true
